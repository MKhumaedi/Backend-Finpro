datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  TENANT
  ADMIN
}

enum BookingStatus {
  WAITING_PAYMENT
  WAITING_CONFIRMATION
  CONFIRMED
  COMPLETED
  CANCELLED
  AUTO_EXPIRED
}

enum RoomStatus {
  Available
  Occupied
  Maintenance
  AVAILABLE
  UNAVAILABLE
  BOOKED
}

enum NotificationType {
  BOOKING
  PRICE
  REVIEW
  MAINTENANCE
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  name               String
  role               Role                @default(USER)
  isVerified         Boolean             @default(false)
  avatarUrl          String?
  loyaltyPoints      Int                 @default(0)
  credits            Decimal             @default(0.00) @db.Decimal(10, 2)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  tenantProfile      TenantProfile?
  bookings           Booking[]
  reviews            Review[]
  notifications      Notification[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]

  @@index([email])
  @@index([role])
}

model TenantProfile {
  id          String     @id @default(uuid())
  userId      String     @unique
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String?
  taxId       String?
  phoneNumber String?
  address     String?    @db.Text
  bankName    String?
  bankAccount String?
  isVerified  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  properties  Property[]

  @@index([userId])
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  deletedAt DateTime?

  @@index([userId])
  @@index([token])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  deletedAt DateTime?
  @@index([userId])
  @@index([token])
}

model PropertyCategory {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  properties  Property[]

  @@index([slug])
}

model Property {
  id              String           @id @default(uuid())
  name            String
  location        String
  city            String           @default("")
  province        String           @default("")
  address         String           @default("")
  latitude        Float            @default(0.0)
  longitude       Float            @default(0.0)
  description     String           @db.Text
  categoryId      String
  category        PropertyCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tenantId        String?
  tenant          TenantProfile?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  beds            Int
  baths           Decimal          @db.Decimal(3, 1)
  sqft            Int
  basePrice       Int
  rating          Decimal          @default(5.0) @db.Decimal(3, 2)
  reviewCount     Int              @default(0)
  imageUrls       String[]
  amenities       String[]
  status          String           @default("ACTIVE")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  rooms           Room[]
  peakSeasonRates PeakSeasonRate[]
  bookings        Booking[]
  reviews         Review[]

  @@index([location])
  @@index([city])
  @@index([categoryId])
  @@index([tenantId])
  @@index([basePrice])
  @@index([rating])
  @@index([status])
}

enum PricingAdjustmentType {
  PERCENTAGE_INCREASE
  FIXED_AMOUNT_INCREASE
}

model Room {
  id              String             @id @default(uuid())
  propertyId      String
  property        Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name            String
  type            String
  capacity        Int
  basePrice       Int
  status          RoomStatus         @default(Available)
  wing            String?
  floor           String?
  image           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  availabilities  RoomAvailability[]
  bookings        Booking[]
  peakSeasonRates PeakSeasonRate[]

  @@index([propertyId])
  @@index([status])
  @@index([basePrice])
}

model RoomAvailability {
  id            String   @id @default(uuid())
  roomId        String
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  date          String
  isBlocked     Boolean  @default(false)
  priceOverride Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  @@unique([roomId, date])
  @@index([roomId])
  @@index([date])
}

model PeakSeasonRate {
  id              String                @id @default(uuid())
  propertyId      String
  property        Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomId          String?
  room            Room?                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  startDate       String
  endDate         String
  rateMultiplier  Decimal               @db.Decimal(4, 2)
  name            String
  adjustmentType  PricingAdjustmentType @default(PERCENTAGE_INCREASE)
  adjustmentValue Decimal               @default(1.50) @db.Decimal(10, 2)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?

  @@index([propertyId])
  @@index([roomId])
  @@index([startDate, endDate])
}

model Booking {
  id           String        @id @default(uuid())
  bookingCode  String        @unique
  guestId      String
  guest        User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  propertyId   String
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  roomId       String?
  room         Room?         @relation(fields: [roomId], references: [id], onDelete: SetNull)
  startDate    String
  endDate      String
  nights       Int
  totalAmount  Decimal       @db.Decimal(10, 2)
  status       BookingStatus @default(WAITING_PAYMENT)
  guestName    String
  guestEmail   String
  guestPhone   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  paymentProof PaymentProof?
  review       Review?

  @@index([bookingCode])
  @@index([guestId])
  @@index([propertyId])
  @@index([roomId])
  @@index([status])
  @@index([startDate, endDate])
}

model PaymentProof {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  proofUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([bookingId])
}

model Review {
  id           String   @id @default(uuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestId      String
  guest        User     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  bookingId    String?  @unique
  booking      Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  guestName    String
  guestAvatar  String?
  rating       Int
  comment      String   @db.Text
  replyComment String?  @db.Text
  replyDate    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
  @@index([propertyId])
  @@index([guestId])
  @@index([bookingId])
  @@index([rating])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([read])
}
